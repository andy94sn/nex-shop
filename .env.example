APP_NAME="NexDistribution Shop"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=ro
APP_FALLBACK_LOCALE=ro
APP_FAKER_LOCALE=ro_RO
APP_SUPPORTED_LOCALES=ro,ru

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=nexdistribution
DB_USERNAME=nexdist
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# ── Cache / Session / Queue ───────────────────────────────────────────────────
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=redis

# ── Cache TTLs (seconds) ──────────────────────────────────────────────────────
CACHE_TTL_MENU=3600
CACHE_TTL_SETTINGS=86400
CACHE_TTL_WISHLIST=2592000
CACHE_TTL_CART=2592000
COMPARE_MAX_PER_CATEGORY=3

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@nexdistribution.md"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_ADMIN_ADDRESS="admin@nexdistribution.md"

# ── Scout / TNTSearch ─────────────────────────────────────────────────────────
SCOUT_DRIVER=tntsearch
SCOUT_QUEUE=true
TNTSEARCH_STORAGE=/tmp/tntsearch
TNTSEARCH_FUZZINESS=false

# ── Media Library ─────────────────────────────────────────────────────────────
MEDIA_DISK=public
